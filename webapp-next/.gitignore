# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# vendored ONNX runtime + VAD assets (copied from node_modules at install)
/public/ort*.mjs
/public/ort*.wasm
/public/silero_vad*.onnx
/public/vad.worklet.bundle.min.js

# typescript
*.tsbuildinfo
next-env.d.ts
